+    def _check_js_availability(self, handle: str) -> dict | None:
+        """Fetch accurate variant availability from Shopify .js endpoint.
+
+        The .json endpoint is unreliable for availability data:
+        - Some stores omit the 'available' field entirely (PlantingTree)
+        - Others return stale values (Spring Hill reports available:true
+          for sold-out items)
+
+        The .js endpoint consistently returns correct availability.
+        No extra polite delay needed — this immediately follows a .json
+        request for the same product.
+
+        Returns dict mapping variant_id -> available (bool), or None on failure.
+        """
+        js_url = f"{self.base_url}/products/{handle}.js"
+        if not is_allowed_by_robots(js_url):
+            return None
+        try:
+            resp = self.session.get(js_url, timeout=15)
+            log_request(js_url, status_code=resp.status_code)
+            if resp.status_code == 200:
+                data = resp.json()
+                return {
+                    v.get("id"): v.get("available")
+                    for v in data.get("variants", [])
+                    if v.get("id") is not None
+                }
+        except Exception as e:
+            logger.debug(f"JS availability check failed for {handle}: {e}")
+        return None
+
